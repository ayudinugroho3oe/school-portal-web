# PostgreSQL connection string used by Prisma and Better Auth.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Generate a high-entropy secret for session signing. Never commit the real value.
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
BOOTSTRAP_SUPER_ADMIN_EMAIL="admin@example.invalid"
BOOTSTRAP_SUPER_ADMIN_PASSWORD="replace-with-a-strong-password"
BOOTSTRAP_SUPER_ADMIN_NAME="Super Admin"
BOOTSTRAP_SCHOOL_CODE="SCHOOL001"
BOOTSTRAP_SCHOOL_NAME="Example School"
